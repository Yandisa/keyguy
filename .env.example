# Copy this file to .env and fill in your values
# In Coolify, set these as Environment Variables in the app settings

# ── REQUIRED ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Tell Django to trust Coolify's HTTPS proxy
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── EMAIL (optional — for quote request notifications) ────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=keyesdiagnosis@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=KeyGuy Boss D <keyesdiagnosis@gmail.com>
